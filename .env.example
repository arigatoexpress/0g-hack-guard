# 0G Hack Guard — Environment Variables
# Copy this file to .env and fill in your credentials.

# ---------------------------------------------------------------------------
# X (Twitter) API v2 — OAuth 1.0a User Context
# ---------------------------------------------------------------------------
# Required for posting tweets and threads.
# Get these from https://developer.x.com/en/portal/dashboard
#   1. Create a Project + App
#   2. Generate "User authentication tokens" (OAuth 1.0a)
#   3. Copy Consumer Key / Secret and Access Token / Secret below.
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ---------------------------------------------------------------------------
# 0G Chain (optional — used by other CLI commands)
# ---------------------------------------------------------------------------
ZGG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZGG_CHAIN_ID=16601
ZGG_RECEIPT_CONTRACT=
